#!/bin/bash

# =================================================================
# HOMELAB "THE GLUE" SCRIPT (Bash Edition)
# =================================================================

echo "🔗 De 'lijm' aanbrengen tussen Vaultwarden, Caddy en je Playbook..."

# 1. Vaultwarden toevoegen aan site.yml (als hij er nog niet in staat)
if ! grep -q "role: vaultwarden" site.yml; then
    echo "📝 Vaultwarden toevoegen aan site.yml..."
    # We voegen hem toe onder de andere rollen
    sed -i '/roles:/a \    - role: vaultwarden' site.yml
else
    echo "✅ Vaultwarden staat al in site.yml"
fi

# 2. Caddyfile template bijwerken
CADDY_TEMPLATE="roles/caddy/templates/Caddyfile.j2"

if [ -f "$CADDY_TEMPLATE" ]; then
    if ! grep -q "vault.{{ duckdns_domain }}" "$CADDY_TEMPLATE"; then
        echo "🌐 Proxy-regels toevoegen aan Caddyfile template..."
        cat <<EOF >> "$CADDY_TEMPLATE"

# Vaultwarden Proxy
vault.{{ duckdns_domain }}.{{ domain }} {
    reverse_proxy vaultwarden:80 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
}
EOF
    else
        echo "✅ Vaultwarden staat al in Caddyfile"
    fi
else
    echo "⚠️  WAARSCHUWING: Caddyfile template niet gevonden op $CADDY_TEMPLATE"
fi

echo "---"
echo "🚀 Klaar! De lijm is droog."
echo "Je kunt nu je playbook draaien met:"
echo "ansible-playbook site.yml --ask-vault-pass"
echo "---"
