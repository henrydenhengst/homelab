# Default configuration
default_config:

# HTTP & trusted proxies
http:
  use_x_forwarded_for: true
  trusted_proxies:
    - 127.0.0.1
    - {{ docker_network_range }}  # Docker network range
    - {{ local_network_range }} # Optioneel: je lokale netwerk

# Database
recorder:
  db_url: postgresql://homeassistant:{{ vault_postgres_password }}@postgres_db/homeassistant
  purge_keep_days: 30
  commit_interval: 30

# Home Assistant core
homeassistant:
  name: "{{ vault_homelab_name }}"
  time_zone: "{{ timezone }}"
  external_url: "https://{{ ha_subdomain }}.{{ duckdns_domain }}.{{ domain }}"
  internal_url: "http://homeassistant:8123"

