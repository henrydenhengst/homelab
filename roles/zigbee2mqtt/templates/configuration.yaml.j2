version: 5
homeassistant:
  enabled: true
permit_join: true

mqtt:
  base_topic: zigbee2mqtt
  server: mqtt://mosquitto:1883
  user: admin
  password: "{{ mqtt_password }}"

serial:
  port: /dev/ttyUSB0
  adapter: zstack

frontend:
  port: 8080
  host: 0.0.0.0

advanced:
  log_level: info
  network_key: {{ z2m_network_key }}
  pan_id: {{ z2m_pan_id }}
  ext_pan_id: {{ z2m_ext_pan_id }}

onboarding: false
