{
    # Gebruik je domeinnaam om een admin-email te genereren voor Let's Encrypt
    email admin@{{ duckdns_domain }}.{{ domain }}
}

# Macro's blijven hetzelfde (die zijn al top)
(duckdns_auth) {
    tls {
        dns duckdns {env.DUCKDNS_TOKEN}
    }
}

(basic_auth) {
    basicauth {
        {{ caddy_admin_user }} {{ caddy_admin_password_hash }}
    }
}

# 1. Home Assistant
{{ ha_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    reverse_proxy {{ name_ha }}:{{ port_ha }}
}

# 2. Hoofddomein (Flame Dashboard)
{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    import basic_auth
    reverse_proxy {{ name_flame }}:{{ port_flame }}
}

# 3. Zigbee2MQTT
{{ zigbee_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    import basic_auth
    reverse_proxy {{ name_zigbee2mqtt }}:{{ port_z2m }}
}

# 4. Vaultwarden
{{ vault_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    reverse_proxy {{ name_vaultwarden }}:{{ port_vaultwarden }}
}

# 5. Portainer
{{ portainer_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    reverse_proxy {{ name_portainer }}:{{ port_portainer }}
}

# 6. ESPHome
{{ esphome_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    import basic_auth
    reverse_proxy {{ name_esphome }}:{{ port_esphome }}
}

# 7. Gotify
{{ gotify_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    reverse_proxy {{ name_gotify }}:{{ port_gotify }}
}

# 8. Mosquitto (MQTT via WebSockets)
{{ mqtt_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    
    basicauth {
        admin {{ mqtt_admin_hash }}
    }

    reverse_proxy {{ name_mosquitto }}:{{ port_mqtt_web }}
}

# 9. Uptime Kuma monitoring
{{ uptime_kuma_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    reverse_proxy {{ uptime_kuma_container_name }}:{{ uptime_kuma_port }}
}

# 10. Dozzle log viewer
{{ dozzle_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    import basic_auth
    reverse_proxy {{ dozzle_container_name }}:{{ dozzle_port }}
}

# 11. Authentik SSO
{{ authentik_subdomain }}.{{ duckdns_domain }}.{{ domain }} {
    import duckdns_auth
    reverse_proxy {{ authentik_container_name_server }}:{{ authentik_port_http }}
}

