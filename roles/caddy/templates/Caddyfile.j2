{
    email {{ acme_email }}
}

# --- Bridge Apps (Direct via Docker DNS) ---
{{ flame_subdomain }}.{{ domain }} {
    reverse_proxy flame:5005
}

{{ zigbee_subdomain }}.{{ domain }} {
    reverse_proxy zigbee2mqtt:8080
}

{{ portainer_subdomain }}.{{ domain }} {
    reverse_proxy portainer:9000
}

# --- Host Mode Apps (Via Docker Gateway IP) ---
{{ ha_subdomain }}.{{ domain }} {
    reverse_proxy 172.17.0.1:8123
}

{{ esphome_subdomain }}.{{ domain }} {
    reverse_proxy 172.17.0.1:6052
}
